        "dark",
        "light",
        "laiqon",
        "amethyst",
        "carbon",
        "graphite",
        "sapphire",
        "ruby",
        "soft",
        "productive",
        "modern"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Laiqon/vscode-laiqon-theme/"
    },
    "bugs": {
        "url": "https://github.com/Laiqon/vscode-laiqon-theme/issues"
    },
    "homepage": "https://github.com/Laiqon/",
    "contributes": {
        "productIconThemes": [
            {
                "id": "laiqon-product-icons",
