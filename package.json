                "path": "./themes/laiqon-carbon.json"
            },
            {
                "label": "Laiqon Amethyst",
                "uiTheme": "vs-dark",
                "path": "./themes/laiqon-amethyst.json"
            },
            {
                "label": "Laiqon Graphite",
                "uiTheme": "vs-dark",
                "path": "./themes/laiqon-graphite.json"
            },
            {
                "label": "Laiqon",
