                "path": "./themes/laiqon.json"
            },
            {
                "label": "Laiqon Light",
                "uiTheme": "vs",
                "path": "./themes/laiqon-light.json"
            },
            {
                "label": "Laiqon Sapphire",
                "uiTheme": "vs-dark",
                "path": "./themes/laiqon-sapphire.json"
            },
            {
                "label": "Laiqon Ruby",
                "uiTheme": "vs-dark",
                "path": "./themes/laiqon-ruby.json"
            }
        ]
