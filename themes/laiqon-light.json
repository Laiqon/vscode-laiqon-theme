/***
    --primary: #FF8C42
    --depth: #F4F4F6
**** COMMON COLORS
    --bg: #f9fafa
**** TOKEN COLORS (your design system)
    --code-title:       #804fb8   → Keywords
    --code-string:      #d22e1b   → Strings
    --code-number:      #2629d7   → Numbers / Booleans
    --code-comment:     #007400   → Comments
    --code-method:      #4a22b0   → Functions / Methods
    --code-preprocessor:#78492b   → Attributes / Decorators
    --code-key:         #ad3ea4   → Properties / Fields
    --code-pointer:     #3e7f87   → Namespaces
    --code-enum:        #37799d   → Enum members
    --code-var:         #027db0   → Variables / Parameters / JSX attributes
    --code-type:        #22575c   → Types / Classes / Interfaces / JSX tags
***/
{
    "$schema": "vscode://schemas/color-theme",
    "name": "Laiqon Light",
    "type": "light",
    "include": "./base/light_plus.json",
    "colors": {
        // Title bar
        "titleBar.activeBackground": "#F4F4F6",
        "titleBar.inactiveBackground": "#F4F4F6",
        "titleBar.border": "#E5E5E9",
        // Activity bar icons
        "activityBar.border": "#E5E5E9",
        "activityBar.background": "#F4F4F6",
        "activityBar.foreground": "#FF8C42",
        "activityBar.inactiveForeground": "#A8A8B0",
        "activityBar.activeBorder": "#FF8C42",
        "activityBarBadge.background": "#FF8C42",
        "activityBarBadge.foreground": "#FFFFFF",
        // Breadcrumb path
        "breadcrumb.background": "#F4F4F6",
        "breadcrumb.foreground": "#7A7A82",
        "breadcrumb.focusForeground": "#FF8C42",
        "breadcrumb.activeSelectionForeground": "#FF8C42",
        // Sidebar (Explorer, etc.)
        "sideBar.background": "#F4F4F6",
        "sideBar.border": "#00000000",
        "sideBarSectionHeader.border": "#E5E5E9",
        // Tabs
        "tab.activeBackground": "#f9fafa",
        "tab.activeForeground": "#FF8C42",
        "tab.activeBorderTop": "#FF8C42",
        "tab.inactiveBackground": "#F4F4F6",
        "tab.inactiveForeground": "#9A9AA2",
        "tab.hoverBackground": "#FF8C4214",
        "tab.border": "#E5E5E9",
        // Code editor
        "editor.background": "#f9fafa",
        "editor.foreground": "#2B2B30",
        "editor.selectionBackground": "#E6E2DD",
        "editor.selectionHighlightBackground": "#FF8C4220",
        "editor.findMatchBackground": "#FF8C4259",
        "editor.findMatchHighlightBackground": "#FF8C4220",
        "editor.wordHighlightBackground": "#FF8C421A",
        "editorCursor.foreground": "#FF8C42",
        // Borders between editors (tabs)
        "editorGroup.border": "#E5E5E9",
        "editorGroupHeader.border": "#00000000",
        "editorGroupHeader.tabsBackground": "#00000000",
        // Bottom panel (Terminal, Problems, Output, etc.)
        "panel.background": "#f9fafa",
        "panel.border": "#E5E5E9",
        // Bottom status bar
        "statusBar.background": "#F4F4F6",
        "statusBar.border": "#E5E5E9",
        "statusBar.foreground": "#FF8C42",
        "statusBar.noFolderBackground": "#f9fafa",
        "statusBar.debuggingBackground": "#FF8C42",
        "statusBar.debuggingForeground": "#f9fafa",
        // Lists (File Explorer, etc.)
        "list.hoverBackground": "#FF8C4214",
        "list.activeSelectionBackground": "#FF8C4226",
        "list.inactiveSelectionBackground": "#FF8C4218",
        "list.focusBackground": "#f9fafa",
        // Scrollbars
        "scrollbarSlider.background": "#C9C6C133",
        "scrollbarSlider.hoverBackground": "#C9C6C155",
        "scrollbarSlider.activeBackground": "#C9C6C188",
        // Buttons
        "button.background": "#FF8C42",
        "button.foreground": "#FFFFFF",
        "dropdown.background": "#f9fafa",
        "input.background": "#f9fafa",
        "textLink.foreground": "#3E7CC2",
        "focusBorder": "#00000000"
    },
    "tokenColors": [
        // ─── COMMENTS ────────────────────────────────────────────────
        {
            "name": "Comments",
            "scope": [
                "comment",
                "comment.block",
                "comment.line",
                "comment.block.documentation",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#007400",
                "fontStyle": "italic"
            }
        },
        // ─── KEYWORDS ────────────────────────────────────────────────
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.control.flow",
                "keyword.operator.new",
                "keyword.other.using",
                "keyword.other.var",
                "storage.modifier",
                "storage.type.class",
                "storage.type.interface",
                "storage.type.enum"
            ],
            "settings": {
                "foreground": "#804fb8"
            }
        },
        // ─── TYPES / CLASSES / INTERFACES ────────────────────────────
        {
            "name": "Types, Classes, Interfaces",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.interface",
                "entity.name.enum",
                "support.class",
                "support.type",
                "storage.type.primitive"
            ],
            "settings": {
                "foreground": "#22575c"
            }
        },
        // ─── FUNCTIONS / METHODS ─────────────────────────────────────
        {
            "name": "Functions and Methods",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call entity.name.function"
            ],
            "settings": {
                "foreground": "#4a22b0",
                "fontStyle": "italic"
            }
        },
        // ─── NAMESPACES ───────────────────────────────────────────────
        {
            "name": "Namespaces",
            "scope": [
                "entity.name.namespace",
                "entity.name.type.namespace",
                "storage.type.namespace"
            ],
            "settings": {
                "foreground": "#3e7f87",
                "fontStyle": "italic"
            }
        },
        // ─── STRINGS ─────────────────────────────────────────────────
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template"
            ],
            "settings": {
                "foreground": "#d22e1b"
            }
        },
        // ─── STRING INTERPOLATION ─────────────────────────────────────
        {
            "name": "String interpolation / template expression",
            "scope": [
                "meta.interpolation",
                "punctuation.definition.template-expression",
                "string.template meta.template.expression"
            ],
            "settings": {
                "foreground": "#d22e1b",
                "fontStyle": ""
            }
        },
        // ─── PARAMETERS ──────────────────────────────────────────────
        {
            "name": "Parameters",
            "scope": [
                "variable.parameter",
                "meta.function.parameters variable.other"
            ],
            "settings": {
                "foreground": "#027db0"
            }
        },
        // ─── PROPERTIES ──────────────────────────────────────────────
        {
            "name": "Properties and fields",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "support.variable.property",
                "meta.object-literal.key",
                "entity.name.variable.field"
            ],
            "settings": {
                "foreground": "#ad3ea4"
            }
        },
        // ─── VARIABLES ───────────────────────────────────────────────
        {
            "name": "Variables",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#027db0"
            }
        },
        // ─── NUMBERS / BOOLEANS ──────────────────────────────────────
        {
            "name": "Numbers and booleans",
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined",
                "constant.language"
            ],
            "settings": {
                "foreground": "#2629d7"
            }
        },
        // ─── ATTRIBUTES (C# / decorators) ────────────────────────────
        {
            "name": "Attributes and decorators",
            "scope": [
                "entity.name.type.attribute",
                "storage.type.attribute",
                "meta.attribute entity.name.function",
                "punctuation.decorator",
                "meta.decorator entity.name.function",
                "meta.decorator variable.other"
            ],
            "settings": {
                "foreground": "#78492b"
            }
        },
        // ─── JSX TAGS (html elements) ────────────────────────────────
        {
            "name": "JSX/TSX — HTML tags",
            "scope": [
                "entity.name.tag",
                "support.class.component",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#22575c"
            }
        },
        // ─── JSX ATTRIBUTES ──────────────────────────────────────────
        {
            "name": "JSX/TSX — attributes",
            "scope": [
                "entity.other.attribute-name",
                "meta.jsx.children entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#027db0"
            }
        },
        // ─── ENUM MEMBERS ─────────────────────────────────────────────
        {
            "name": "Enum members",
            "scope": [
                "variable.other.enummember"
            ],
            "settings": {
                "foreground": "#37799d"
            }
        },
        // ─── PUNCTUATION ─────────────────────────────────────────────
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "meta.brace",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#6E6E78"
            }
        },
        // ─── OPERATORS ───────────────────────────────────────────────
        {
            "name": "Operators",
            "scope": [
                "keyword.operator",
                "storage.type.function.arrow"
            ],
            "settings": {
                "foreground": "#6E6E78"
            }
        }
    ]
}