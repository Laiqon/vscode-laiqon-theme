/***
    --primary: #FF8C42
    --depth: #000000
**** COMMON COLORS
    --bg: #141414
**** TOKEN COLORS (your design system)
    --code-title:       #b283ec   → Keywords
    --code-string:      #ff8170   → Strings
    --code-number:      #d8c97c   → Numbers / Booleans
    --code-comment:     #7e8c98   → Comments
    --code-method:      #dabaff   → Functions / Methods
    --code-preprocessor:#ffa14f   → Attributes / Decorators
    --code-key:         #ff7ab2   → Properties / Fields
    --code-pointer:     #78c2b4   → Namespaces
    --code-enum:        #6bdfff   → Enum members
    --code-var:         #4eb0cb   → Variables / Parameters / JSX attributes
    --code-type:        #acf2e4   → Types / Classes / Interfaces / JSX tags
***/
{
    "$schema": "vscode://schemas/color-theme",
    "name": "Laiqon",
    "type": "dark",
    "include": "./base/dark_plus.json",
    "colors": {
        // Title bar
        "titleBar.activeBackground": "#141414",
        "titleBar.inactiveBackground": "#141414",
        "titleBar.border": "#00000000",
        // Activity bar icons
        "activityBar.border": "#FF8C4210",
        "activityBar.background": "#141414",
        "activityBar.foreground": "#FF8C42",
        "activityBar.inactiveForeground": "#D6DAE0",
        "activityBar.activeBorder": "#FF8C42",
        "activityBarBadge.background": "#FF8C42",
        "activityBarBadge.foreground": "#FFFFFF",
        // Breadcrumb path
        "breadcrumb.background": "#000000",
        "breadcrumb.foreground": "#6C727F",
        "breadcrumb.focusForeground": "#FF8C42",
        "breadcrumb.activeSelectionForeground": "#FF8C42",
        // Sidebar (Explorer, etc.)
        "sideBar.background": "#000000",
        "sideBar.border": "#00000000",
        "sideBarSectionHeader.border": "#FF8C4210",
        // Tabs
        "tab.activeBackground": "#00000090",
        "tab.activeForeground": "#FF8C42",
        "tab.activeBorderTop": "#FF8C42",
        "tab.inactiveBackground": "#00000050",
        "tab.inactiveForeground": "#9AA3AD",
        "tab.hoverBackground": "#FF8C4220",
        "tab.border": "#141414",
        // Code editor
        "editor.background": "#141414",
        "editor.foreground": "#D6DAE0",
        "editor.selectionBackground": "#FF8C4210",
        "editor.selectionHighlightBackground": "#FF8C4220",
        "editor.findMatchBackground": "#FF8C4259",
        "editor.findMatchHighlightBackground": "#FF8C4220",
        "editor.wordHighlightBackground": "#FF8C421A",
        "editorCursor.foreground": "#FF8C42",
        // Borders between editors (tabs)
        "editorGroup.border": "#FF8C4210",
        "editorGroupHeader.border": "#00000000",
        "editorGroupHeader.tabsBackground": "#00000000",
        // Bottom panel (Terminal, Problems, Output, etc.)
        "panel.background": "#141414",
        "panel.border": "#FF8C4210",
        // Bottom status bar
        "statusBar.background": "#000000",
        "statusBar.border": "#FF8C4210",
        "statusBar.foreground": "#FF8C42",
        "statusBar.noFolderBackground": "#0e0e0e",
        "statusBar.debuggingBackground": "#FF8C42",
        "statusBar.debuggingForeground": "#0e0e0e",
        // Lists (File Explorer, etc.)
        "list.hoverBackground": "#FF8C4220",
        "list.activeSelectionBackground": "#FF8C4250",
        "list.inactiveSelectionBackground": "#FF8C4220",
        "list.focusBackground": "#252527",
        // Scrollbars
        "scrollbarSlider.background": "#FF8C4290",
        "scrollbarSlider.hoverBackground": "#FF8C4250",
        "scrollbarSlider.activeBackground": "#FF8C4280",
        // Buttons
        "button.background": "#FF8C4250",
        "button.foreground": "#D6DAE0",
        "dropdown.background": "#0e0e0e",
        "input.background": "#0e0e0e",
        "textLink.foreground": "#67B5FF",
        "focusBorder": "#00000000"
    },
    "tokenColors": [
        // ─── COMMENTS ────────────────────────────────────────────────
        {
            "name": "Comments",
            "scope": [
                "comment",
                "comment.block",
                "comment.line",
                "comment.block.documentation",
                "punctuation.definition.comment"
            ],
            "settings": {
                "foreground": "#7e8c98",
                "fontStyle": "italic"
            }
        },
        // ─── KEYWORDS ────────────────────────────────────────────────
        {
            "name": "Keywords",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.control.flow",
                "keyword.operator.new",
                "keyword.other.using",
                "keyword.other.var",
                "storage.modifier",
                "storage.type.class",
                "storage.type.interface",
                "storage.type.enum"
            ],
            "settings": {
                "foreground": "#b283ec"
            }
        },
        // ─── TYPES / CLASSES / INTERFACES ────────────────────────────
        {
            "name": "Types, Classes, Interfaces",
            "scope": [
                "entity.name.type",
                "entity.name.class",
                "entity.name.interface",
                "entity.name.enum",
                "support.class",
                "support.type",
                "storage.type.primitive"
            ],
            "settings": {
                "foreground": "#acf2e4"
            }
        },
        // ─── FUNCTIONS / METHODS ─────────────────────────────────────
        {
            "name": "Functions and Methods",
            "scope": [
                "entity.name.function",
                "support.function",
                "meta.function-call entity.name.function"
            ],
            "settings": {
                "foreground": "#dabaff",
                "fontStyle": "italic"
            }
        },
        // ─── NAMESPACES ───────────────────────────────────────────────
        {
            "name": "Namespaces",
            "scope": [
                "entity.name.namespace",
                "entity.name.type.namespace",
                "storage.type.namespace"
            ],
            "settings": {
                "foreground": "#78c2b4",
                "fontStyle": "italic"
            }
        },
        // ─── STRINGS ─────────────────────────────────────────────────
        {
            "name": "Strings",
            "scope": [
                "string",
                "string.quoted",
                "string.template"
            ],
            "settings": {
                "foreground": "#ff8170",
            }
        },
        // ─── STRING INTERPOLATION ─────────────────────────────────────
        {
            "name": "String interpolation / template expression",
            "scope": [
                "meta.interpolation",
                "punctuation.definition.template-expression",
                "string.template meta.template.expression"
            ],
            "settings": {
                "foreground": "#ff8170",
                "fontStyle": ""
            }
        },
        // ─── PARAMETERS ──────────────────────────────────────────────
        {
            "name": "Parameters",
            "scope": [
                "variable.parameter",
                "meta.function.parameters variable.other"
            ],
            "settings": {
                "foreground": "#4eb0cb"
            }
        },
        // ─── PROPERTIES ──────────────────────────────────────────────
        {
            "name": "Properties and fields",
            "scope": [
                "variable.other.property",
                "variable.other.object.property",
                "support.variable.property",
                "meta.object-literal.key",
                "entity.name.variable.field"
            ],
            "settings": {
                "foreground": "#ff7ab2"
            }
        },
        // ─── VARIABLES ───────────────────────────────────────────────
        {
            "name": "Variables",
            "scope": [
                "variable",
                "variable.other",
                "variable.other.readwrite"
            ],
            "settings": {
                "foreground": "#4eb0cb"
            }
        },
        // ─── NUMBERS / BOOLEANS ──────────────────────────────────────
        {
            "name": "Numbers and booleans",
            "scope": [
                "constant.numeric",
                "constant.language.boolean",
                "constant.language.null",
                "constant.language.undefined",
                "constant.language"
            ],
            "settings": {
                "foreground": "#d8c97c"
            }
        },
        // ─── ATTRIBUTES (C# / decorators) ────────────────────────────
        {
            "name": "Attributes and decorators",
            "scope": [
                "entity.name.type.attribute",
                "storage.type.attribute",
                "meta.attribute entity.name.function",
                "punctuation.decorator",
                "meta.decorator entity.name.function",
                "meta.decorator variable.other"
            ],
            "settings": {
                "foreground": "#ffa14f"
            }
        },
        // ─── JSX TAGS (html elements) ────────────────────────────────
        {
            "name": "JSX/TSX — HTML tags",
            "scope": [
                "entity.name.tag",
                "support.class.component",
                "punctuation.definition.tag"
            ],
            "settings": {
                "foreground": "#acf2e4"
            }
        },
        // ─── JSX ATTRIBUTES ──────────────────────────────────────────
        {
            "name": "JSX/TSX — attributes",
            "scope": [
                "entity.other.attribute-name",
                "meta.jsx.children entity.other.attribute-name"
            ],
            "settings": {
                "foreground": "#4eb0cb"
            }
        },
        // ─── ENUM MEMBERS ─────────────────────────────────────────────
        {
            "name": "Enum members",
            "scope": [
                "variable.other.enummember"
            ],
            "settings": {
                "foreground": "#6bdfff"
            }
        },
        // ─── PUNCTUATION ─────────────────────────────────────────────
        {
            "name": "Punctuation",
            "scope": [
                "punctuation",
                "meta.brace",
                "punctuation.separator",
                "punctuation.terminator"
            ],
            "settings": {
                "foreground": "#5C5C64"
            }
        },
        // ─── OPERATORS ───────────────────────────────────────────────
        {
            "name": "Operators",
            "scope": [
                "keyword.operator",
                "storage.type.function.arrow"
            ],
            "settings": {
                "foreground": "#5C5C64"
            }
        }
    ]
}